{
  "name": "codle-mcp",
  "version": "1.0.0",
  "description": "Codle MCP Server - MCP tools for managing Codle learning materials",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:e2e": "DOTENV_CONFIG_PATH=.env.e2e node dist/index.js",
    "e2e": "vitest run --config e2e/vitest.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lexical/code": "^0.32.1",
    "@lexical/headless": "^0.32.1",
    "@lexical/link": "^0.32.1",
    "@lexical/list": "^0.32.1",
    "@lexical/markdown": "^0.32.1",
    "@lexical/rich-text": "^0.32.1",
    "@lexical/table": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "lexical": "^0.32.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
