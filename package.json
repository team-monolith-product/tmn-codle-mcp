{
  "name": "codle-cli",
  "version": "1.0.0",
  "description": "Codle CLI tools for managing Codle learning materials",
  "type": "module",
  "bin": {
    "codle": "./bin/run.js"
  },
  "scripts": {
    "build": "tsc",
    "e2e": "vitest run --config e2e/vitest.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "oclif": {
    "bin": "codle",
    "dirname": "codle",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "topicSeparator": " "
  },
  "dependencies": {
    "@lexical/code": "^0.32.1",
    "@lexical/headless": "^0.32.1",
    "@lexical/link": "^0.32.1",
    "@lexical/list": "^0.32.1",
    "@lexical/markdown": "^0.32.1",
    "@lexical/rich-text": "^0.32.1",
    "@lexical/table": "^0.32.1",
    "@oclif/core": "^4.3.0",
    "dotenv": "^16.4.7",
    "lexical": "^0.32.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
