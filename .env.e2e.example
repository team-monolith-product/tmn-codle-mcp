# E2E 테스트 환경 변수
# 이 파일을 .env.e2e로 복사하여 사용하세요: cp .env.e2e.example .env.e2e

# E2E 테넌트 번호
# 설정 시 URL이 자동 구성됨: class.{n}.e2e.codle.io, user.{n}.e2e.codle.io
E2E_TENANT_NUMBER=17

# Doorkeeper OAuth Application client_id (password grant에 필요)
E2E_USER_CLIENT_ID=dXRY51oKJANvLOjM90EHooog2WdJmhTpz1eQjTv826M

# Claude model for E2E tests (sonnet, haiku, opus)
E2E_MODEL=sonnet

# E2E 반복 횟수 (1=1회 실행, 10=10회 실행)
E2E_REPEATS=1
